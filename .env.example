# ─────────────────────────────────────────────────────────────────────────────
# OpenFraudMonitoring — Build & Runtime Configuration
# Copy this file to .env and adjust values for your environment.
# docker-compose reads this file automatically.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=ofm
POSTGRES_PASSWORD=ofm
POSTGRES_DB=ofm
DATABASE_URL=postgresql://ofm:ofm@db:5432/ofm

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_USER=ofm
RABBITMQ_PASSWORD=ofm
RABBITMQ_URL=amqp://ofm:ofm@rabbitmq:5672/

# ── Backend server ────────────────────────────────────────────────────────────
FLASK_DEBUG=0
PORT=5000
LOG_LEVEL=DEBUG

# ── Authentication / RBAC ────────────────────────────────────────────────────
# Secret used to sign JWT tokens. MUST be changed in production.
JWT_SECRET=change-me-in-production
# Default admin account created on first boot.
OFM_ADMIN_USERNAME=admin
OFM_ADMIN_PASSWORD=admin
# Bootstrap API token for the admin account.
# Connectors use this token to self-register on first start.
OFM_ADMIN_TOKEN=dev-admin-token

# ── Intelligence ──────────────────────────────────────────────────────────────
INTEL_DECAY_DAYS=7

# ── Worker ────────────────────────────────────────────────────────────────────
PERIODIC_INTERVAL_SECONDS=60

# ── Build / Debug ────────────────────────────────────────────────────────────
OFM_DEBUG=true

# ── Client (ofm.js) ──────────────────────────────────────────────────
# The URL the ofm.js client sends data to.
# Leave empty for same-origin (client served from same domain as backend).
# Set to a full URL (e.g. https://ofm.example.com) for cross-origin collection.
OFM_SERVER_URL=

# ── Connectors ───────────────────────────────────────────────────────────────
BACKEND_URL=http://backend:5000
