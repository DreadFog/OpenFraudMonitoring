# ─────────────────────────────────────────────────────────────────────────────
# OpenFraudMonitoring — Build & Runtime Configuration
# Copy this file to .env and adjust values for your environment.
# docker-compose reads this file automatically.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=ofm
POSTGRES_PASSWORD=ofm
POSTGRES_DB=ofm
DATABASE_URL=postgresql://ofm:ofm@db:5432/ofm

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Backend server ────────────────────────────────────────────────────────────
FLASK_DEBUG=0
PORT=5000

# ── Worker ────────────────────────────────────────────────────────────────────
PERIODIC_INTERVAL_SECONDS=60

# ── Client (fingerprint.js) ──────────────────────────────────────────────────
# The URL the fingerprint.js client sends data to.
# Leave empty for same-origin (client served from same domain as backend).
# Set to a full URL (e.g. https://ofm.example.com) for cross-origin collection.
OFM_SERVER_URL=

# ── Frontend dashboard ───────────────────────────────────────────────────────
# Backend URL used by the React dashboard during build (mainly for nginx proxy).
REACT_APP_API_URL=http://localhost:5000
